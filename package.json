{
  "name": "readme-generator-ai",
  "version": "1.0.0",
  "description": "Auto-generate professional READMEs for any repository using AI",
  "main": "dist/core/index.js",
  "bin": {
    "readme-gen": "./bin/readme-gen.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:cli && next build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepack": "npm run build:cli",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf dist .next"
  },
  "keywords": ["readme", "generator", "ai", "documentation"],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "commander": "^11.0.0",
    "openai": "^4.0.0",
    "@octokit/rest": "^20.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0"
  }
}
